{
  "kind": "collectionType",
  "collectionName": "leads",
  "info": {
    "singularName": "lead",
    "pluralName": "leads",
    "displayName": "Lead",
    "description": "Collected leads from website"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "phone": {
      "type": "string"
    },
    "company": {
      "type": "string"
    },
    "industry": {
      "type": "string"
    },
    "jobTitle": {
      "type": "string"
    },
    "message": {
      "type": "text"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "Automatic Login",
        "Talk to our team"
      ],
      "default": "Talk to our team"
    },
    "source": {
      "type": "string",
      "default": "Website"
    }
  }
}
