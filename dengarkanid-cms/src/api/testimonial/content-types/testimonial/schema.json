{
  "kind": "collectionType",
  "collectionName": "testimonials",
  "info": {
    "singularName": "testimonial",
    "pluralName": "testimonials",
    "displayName": "Testimonial",
    "description": "Customer testimonials shown in the homepage marquee section"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "quote": {
      "type": "text",
      "required": true
    },
    "name": {
      "type": "string",
      "required": true
    },
    "location": {
      "type": "string",
      "required": false
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "cardColor": {
      "type": "enumeration",
      "enum": ["red", "orange", "yellow", "green", "blue", "purple"],
      "default": "blue",
      "required": true
    },
    "row": {
      "type": "enumeration",
      "enum": ["top", "middle", "bottom"],
      "default": "top",
      "required": true
    },
    "isActive": {
      "type": "boolean",
      "default": true
    }
  }
}
